    "lucide-vue-next": "^1.0.0",
    "merge": "^2.1.1",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "vee-validate": "^4.15.1",
    "vue": "beta",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.4",
    "vue-sonner": "^2.0.9",
